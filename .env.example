# LLM設定 (Llama API / OpenAI 互換サーバー)
LLAMA_ENDPOINT="http://localhost:8080/"
LLAMA_API_KEY="your_api_key_here"
LLAMA_MODEL="local-model"

# Slack設定
SLACK_BOT_TOKEN="xoxb-your-token-here"
SLACK_CHANNEL_ID="C0XXXXXXXXX"

# ボットの身元情報 (User-Agentに使用)
BOT_EMAIL="your_email@example.com"

# システム設定
DB_PATH=./data/collector.db
